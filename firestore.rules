rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSuperAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'hiwa.constructions@gmail.com' ||
        request.auth.token.email == '9647500000000@iqmotors.app'
      );
    }

    function isCarOwner() {
      return request.auth != null
        && resource.data.sellerId == request.auth.uid;
    }

    function isCarOwnerOnCreate() {
      return request.auth != null
        && request.resource.data.sellerId == request.auth.uid;
    }

    function sellerIdUnchanged() {
      return !('sellerId' in request.resource.data)
        || request.resource.data.sellerId == resource.data.sellerId;
    }

    function onlyBidFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['highestBid', 'lastBidAt', 'lastBidBy']);
    }

    function onlyLikedByUsersChanged() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['likedByUsers']);
    }

    match /users/{userId} {
      allow read: if request.auth != null
        && (request.auth.uid == userId || isSuperAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    match /cars/{carId} {
      allow read: if true;

      allow create: if isCarOwnerOnCreate();

      allow update: if isSuperAdmin()
        || (isCarOwner() && sellerIdUnchanged())
        || (request.auth != null && onlyBidFieldsChanged())
        || (request.auth != null && onlyLikedByUsersChanged());

      allow delete: if isSuperAdmin() || isCarOwner();

      match /bids/{bidId} {
        function isBidCarOwner() {
          return request.auth != null
            && get(/databases/$(database)/documents/cars/$(carId)).data.sellerId
              == request.auth.uid;
        }

        allow read: if isSuperAdmin() || isBidCarOwner();

        allow create: if request.auth != null
          && request.resource.data.keys().hasOnly([
            'amount', 'bidderName', 'bidderPhone', 'bidderId', 'createdAt'
          ])
          && request.resource.data.amount is int
          && request.resource.data.amount > 0;

        allow update, delete: if false;
      }
    }

    // Brand → model → trim catalog for filters and listing forms.
    match /car_metadata/{brandId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Normalized catalog imported from Data/*.csv (source of truth).
    match /catalog_brands/{brandId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /catalog_models/{modelId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /catalog_trims/{trimId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Platform settings (package prices, cities, R2 credentials).
    // Contains secrets — super admins only.
    match /system_config/{docId} {
      allow read, write: if isSuperAdmin();
    }

    // Bid notifications for car owners.
    match /messages/{messageId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null
        && request.auth.uid == resource.data.recipientId;
    }
  }
}
