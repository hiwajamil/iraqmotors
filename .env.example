# Cloudflare R2 (S3-compatible). Copy this file to `.env` and fill in your values.
# Never commit `.env` to git.

R2_BUCKET_NAME=iqmotors-media
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
# Public URL base — enable R2.dev public access in Cloudflare dashboard first.
# R2 → iqmotors-media → Settings → Public access → Allow Access → copy URL here.
R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
R2_REGION=auto

# Optional: Cloudflare API token (R2 Edit) for tool/r2_enable_public.mjs
# CLOUDFLARE_ACCOUNT_ID=e5c493b87507d1d2efbeac09b1ee959d
# CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Google Gemini API key for AI auto-fill on car photos.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
